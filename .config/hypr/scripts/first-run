#!/bin/bash

MARKER="$HOME/.local/state/symphony/first-run.mode"
[[ ! -f "$MARKER" ]] && exit 0
rm -f "$MARKER"

# Wait for Hyprland to initialize
sleep 2

# Apply default theme
~/dotfiles/install/themes/symphony switch sakura

# Welcome notifications
notify-send -u critical -i dialog-information "Welcome to Symphony" "Run 'symphony help' for available commands."
notify-send -u critical -i input-keyboard "Keybindings" "Press Super + K to view all keybindings"
notify-send -u critical -i applications-other "App Launcher" "Press Super + Space to launch apps"

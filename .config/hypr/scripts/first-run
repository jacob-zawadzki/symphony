#!/bin/bash

MARKER="$HOME/.local/state/symphony/first-run.mode"
[[ ! -f "$MARKER" ]] && exit 0
rm -f "$MARKER"

# Wait for Hyprland to initialize
sleep 2

# Apply default theme
~/dotfiles/install/themes/symphony switch sakura

# Welcome notifications
notify-send -u critical "App Launcher" "Press Super + Space to launch apps"
notify-send -u critical "Keybindings" "Press Super + K to view all keybindings"
notify-send -u critical "Welcome to Symphony" "Run 'symphony help' for available commands."
